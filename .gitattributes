# See https://git-scm.com/docs/gitattributes for more about git attribute files.

# Force LF everywhere in the monorepo
* text=auto eol=lf

# Explicit script safety
*.sh text eol=lf
bin/* text eol=lf

# Lock common languages
*.rb text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
